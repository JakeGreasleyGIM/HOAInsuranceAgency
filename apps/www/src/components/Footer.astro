---
import { PHONE, PHONE_HREF, EMAIL, EMAIL_HREF, ADDRESS_LINE1, ADDRESS_LINE2, SOCIAL } from "../constants";
import "./Footer.css";
---

<footer class="footer">
  <div class="footer-inner container">
    <img src="/logo.png" alt="HOA Insurance Agency" class="footer-logo" />

    <div class="footer-contact">
      <p class="footer-address">{ADDRESS_LINE1}<br />{ADDRESS_LINE2}</p>
      <a href={EMAIL_HREF} class="footer-link">{EMAIL}</a>
      <a href={PHONE_HREF} class="footer-link">{PHONE}</a>
    </div>

    <div class="footer-social">
      <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href={SOCIAL.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
      </a>
      <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-4 0v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
      </a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <nav class="footer-nav">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/terms-of-service">Terms of Service</a>
      </nav>
      <p>&copy; {new Date().getFullYear()} HOA Insurance Agency. All rights reserved.</p>
    </div>
  </div>
</footer>
